---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const images = import.meta.glob<{ default: ImageMetadata }>('../assets/logos/*.{png,jpg,jpeg,svg,webp}', { eager: true });

const sponsors = [
  { tier: 'diamante', color: '#00B4B4', logos: [
    { name: 'Guatifer', src: '../assets/logos/guatifer.png', url: 'https://www.guatiferusinagem.com.br/' },
    { name: 'SENAI', src: '../assets/logos/senai.png', url: 'https://www.sp.senai.br/unidade/santoandre/' }
  ]},
  { tier: 'ouro', color: '#D4AF37', logos: [
    { name: 'Balanças Siciliano', src: '../assets/logos/siciliano.png', url: 'https://sicilianobalancas.com.br/' },
    { name: 'Engineering Simulation And Scientific Software', src: '../assets/logos/esss.png', url: 'https://www.esss.com' },
    { name: 'Fundação Universidade Federal do ABC', src: '../assets/logos/ufabc.png', url: 'https://www.ufabc.edu.br' },
    { name: 'InovaUFABC Agência de Inovação', src: '../assets/logos/inova.png', url: 'https://inova.ufabc.edu.br' },
    { name: 'Rainha das Tintas', src: '../assets/logos/rainha.png', url: 'http://www.rainhadastintas.com.br' },
    { name: 'Space Farming Brazil', src: '../assets/logos/spacefarming.png', url: 'https://www.embrapa.br/en/pecuaria-sudeste/agricultura-espacial' }
  ]},
  { tier: 'prata', color: '#A8A8A8', logos: [
    { name: 'Altair Engineering', src: '../assets/logos/altair.png', url: 'https://altair.com' },
    { name: 'Ansys', src: '../assets/logos/ansys.png', url: 'https://www.ansys.com' },
    { name: 'Bizu Space', src: '../assets/logos/bizu.png', url: 'https://www.bizu.space/pt' },
    { name: 'BrasFila', src: '../assets/logos/brasfila.png', url: 'https://www.brasfila.com.br/' },
    { name: 'Circuibras', src: '../assets/logos/circuibras.png', url: 'https://circuibras.com.br' },
    { name: 'GPDA', src: '../assets/logos/gpda.png', url: 'https://www.gpdaufabc.tech' },
    { name: 'Jade Art\'s', src: '../assets/logos/jade.png', url: 'https://www.facebook.com/artesjade/' },
    { name: 'Mac Jee', src: '../assets/logos/macjee.png', url: 'https://macjee.com.br' },
    { name: 'Math Works', src: '../assets/logos/mathworks.png', url: 'https://www.mathworks.com/' },
    { name: 'MTB Mantas Térmicas', src: '../assets/logos/mtb.png', url: 'https://mantamtb.com' },
    { name: 'Multitech', src: '../assets/logos/multitech.png', url: 'https://multittech.com.br' },
    { name: 'Rubber Plast', src: '../assets/logos/rubberplast.png', url: 'https://www.rubberplast.com.br' },
    { name: 'Spawn Pinturas', src: '../assets/logos/spawnpinturas.png', url: 'https://www.facebook.com/SPAWNPINTURAS' },
    { name: 'Texiglass', src: '../assets/logos/texiglass.png', url: 'https://texiglass.com.br/' },
    { name: 'WR Metais', src: '../assets/logos/wrmetais.png', url: 'https://www.facebook.com/p/Wr-Metais-100063988244180/' }
  ]},
  { tier: 'bronze', color: '#CD7F32', logos: [
    { name: 'Redelease', src: '../assets/logos/redelease.png', url: 'https://www.redelease.ind.br/' },
    { name: 'MaxiAr', src: '../assets/logos/maxiar.png', url: 'https://www.maxiar.com.br/' },
    { name: 'LOCFER', src: '../assets/logos/locfer.png', url: 'https://locfer.com.br' }
  ]},
];
---

<section class="sponsor-container">
  {sponsors.map((group) => (
    <div class="tier-row">
      <div class="sidebar" style={`background-color: ${group.color}`}>
        <span>{group.tier}</span>
      </div>

      <div class="logo-grid">
        {group.logos.map((logo) => {
          const imagePath = images[logo.src];
          
          return (
            <a href={logo.url} target="_blank" rel="noopener noreferrer" class="logo-card">
              {imagePath ? (
                <Image 
                  src={imagePath.default} 
                  alt={logo.name}
                  width={400} 
                  loading="lazy"
                  class="sponsor-logo"
                />
              ) : (
                <p class="placeholder-text">{logo.name}</p>
              )}
            </a>
          );
        })}
      </div>
    </div>
  ))}
</section>

<style>
  .sponsor-container {
    display: flex;
    flex-direction: column;
    gap: 24px;
    width: 95%;
    max-width: 1200px;
    margin: 0 auto;
    margin-bottom: 3rem;
  }

  .tier-row {
    display: flex;
    width: 100%;
    min-height: 200px;
  }

  .sidebar {
    width: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: bold;
    font-size: 2rem;
    text-transform: lowercase;
  }

  .sidebar span {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  .logo-grid {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    align-items: center;
    gap: 40px;
    padding: 30px;
  }

  .logo-card {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 180px; 
    transition: transform 0.2s;
  }

  .logo-card img {
    max-width: 100%;
    height: auto;
    max-height: 80px;
  }
  
  .sponsor-logo {
    width: 100%;
    height: auto;
    max-height: 80px;
    object-fit: contain;
  }
  .placeholder-text {
    color: white;
    font-size: 0.9rem;
  }
</style>