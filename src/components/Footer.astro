---
import { Image } from 'astro:assets';
import Social from '../components/Social.astro';
import logo from '../assets/logo.png'
---

<footer>
  <div class="footer-contacts">
    <p>Siga-nos!</p>
    <a href="https://www.instagram.com/ufabcrocketdesign/" target="_blank">Instagram</a>
    <a href="https://www.linkedin.com/company/ufabc-rocket-design/" target="_blank">LinkedIn</a>
  </div>
  <div class="container">
    <div class="footer-brand">
      <Image src={logo} alt="Logo da equipe" loading={'lazy'} width={128}/>
      <span>UFABC Rocket Design</span>
    </div>
    <div class="footer-quote">
      <p class="latin">"Per Aspera Ad Astra"</p>
      <p class="translation">Através das dificuldades, até as estrelas</p>
    </div>
    <nav class="footer-nav">
      <a href="#equipe">A EQUIPE</a>
      <a href="#membros">MEMBROS</a>
      <a href="#apoio">APOIO</a>
    </nav>
  </div>
  <hr />
  <div class="footer-bottom">
    <p>foguetes@ufabc.edu.br - UFABC Rocket Design - Feito orgulhosamente pelos nossos membros</p>
  </div>
</footer>

<style lang="scss">
  footer {
    padding: 40px 1% 20px;

    .footer-contacts {
      display: flex;
      justify-content: center;
      gap: 1rem;

      a {
        color: rgba(white, 1);
      }
    }

    .container {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 20px;
    }
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 15px;
    font-size: 1.8rem;
    font-weight: 500;
    justify-self: start;
  }

  .footer-quote {
    text-align: center;
    justify-self: center;

    .latin {
      font-size: 1.2rem;
      margin-bottom: 5px;
    }

    .translation {
      font-size: 0.95rem;
      font-weight: 300;
    }
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;

    a {
      text-decoration: none;
      color: inherit;
      font-size: 0.9rem;
      font-weight: 500;
      transition: opacity 0.2s;

      &:hover {
        opacity: 0.7;;
      }
    }
  }

  hr {
    border: 0;
    border-top: 1px solid #ccc;
    margin: 30px 0 15px;
  }

  .footer-bottom {
    text-align: center;
    font-size: 0.85rem;
    font-weight: 400;

    p {
      font-size: 1rem
    }
  }
</style>